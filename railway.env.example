# HemSolutions Backend - Railway Deployment Environment Variables
# Copy these to your Railway project variables panel (Dashboard > Variables)
# Replace all placeholder values with your actual credentials

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=3001
NODE_ENV=production

# =============================================================================
# DATABASE - Railway Postgres (Auto-provisioned or external)
# =============================================================================
# Railway automatically provides DATABASE_URL if you add a Postgres service
# Format: postgresql://username:password@host:port/database
# If using Railway's managed Postgres, this will be auto-populated
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Alternative: Manual database URL (if using external database)
# DATABASE_URL=postgresql://user:pass@host:5432/hemsolutions

# =============================================================================
# REDIS - Railway Redis (Auto-provisioned or external)
# =============================================================================
# Railway automatically provides REDIS_URL if you add a Redis service
# If using Railway's managed Redis, this will be auto-populated
REDIS_URL=${{Redis.REDIS_URL}}

# Alternative: External Redis service (Upstash, Redis Cloud, etc.)
# REDIS_URL=redis://default:password@host:port

# =============================================================================
# JWT SECURITY - GENERATE STRONG SECRETS NOW!
# =============================================================================
# Run this command in your terminal to generate:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# 
# Generate TWO different secrets and paste them below:
JWT_SECRET=YOUR_128_CHARACTER_HEX_SECRET_HERE_GENERATE_WITH_COMMAND_ABOVE
JWT_REFRESH_SECRET=YOUR_DIFFERENT_128_CHARACTER_HEX_SECRET_HERE
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# STRIPE PAYMENTS - REQUIRED FOR PAYMENT PROCESSING
# =============================================================================
# Get your keys from: https://dashboard.stripe.com/apikeys
# For testing: Use test keys (pk_test_*, sk_test_*)
# For production: Use live keys (pk_live_*, sk_live_*)

STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_TEST_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_TEST_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# =============================================================================
# SENDGRID EMAIL - REQUIRED FOR EMAIL NOTIFICATIONS
# =============================================================================
# Get API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.YOUR_SENDGRID_API_KEY_HERE
EMAIL_FROM=info@hemsolutions.se
EMAIL_FROM_NAME=HemSolutions Sverige AB

# =============================================================================
# FRONTEND URL - UPDATE AFTER FRONTEND DEPLOYMENT
# =============================================================================
# This should match your Netlify deployment URL
# Will be updated after frontend is deployed
FRONTEND_URL=https://hemsolutions-frontend.netlify.app

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# OPTIONAL: SENTRY ERROR TRACKING
# =============================================================================
# Get DSN from: https://sentry.io/signup/
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# =============================================================================
# OPTIONAL: BANKID INTEGRATION (Swedish Authentication)
# =============================================================================
# For production BankID, contact a BankID vendor
# For testing: https://www.bankid.com/en/utvecklare/test
BANKID_API_URL=https://appapi2.test.bankid.com/rp/v5.1
BANKID_PFX_PATH=/path/to/your/bankid.p12
BANKID_PFX_PASSPHRASE=your_pfx_passphrase

# =============================================================================
# OPTIONAL: SWISH PAYMENT INTEGRATION
# =============================================================================
# For testing: https://developer.swish.nu/
SWISH_API_URL=https://mss.cpc.getswish.net/swish-cpcapi/api/v1
SWISH_MERCHANT_ID=1231181189
SWISH_CERT_PATH=/path/to/your/swish.pem
SWISH_KEY_PATH=/path/to/your/swish.key
